# --- Neon Postgres ---
# Pooled connection (PgBouncer) for the app runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true"
# Direct connection (no -pooler) for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- Auth.js ---
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="your-generated-secret"
AUTH_URL="http://localhost:3000"

# --- Email (Resend) ---
# Create a key at https://resend.com (API Keys). On the free tier without a
# verified domain, emails only deliver to your own Resend account address.
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Slotly <onboarding@resend.dev>"

# --- Stripe (test mode) ---
# Secret key from dashboard.stripe.com (Developers -> API keys).
STRIPE_SECRET_KEY="sk_test_xxxxxxxx"
# Created by: npm run stripe:setup
STRIPE_PRO_PRICE_ID="price_xxxxxxxx"
# From `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"
