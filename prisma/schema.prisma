// Slotly — multi-tenant booking SaaS schema.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URLs live in prisma.config.ts (migrate) and the
  // driver adapter passed to PrismaClient (runtime), not here.
}

// ============================================================
// Auth.js (NextAuth) — user accounts & OAuth plumbing
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // null for OAuth-only accounts; set for email/password sign-ups
  passwordHash  String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  staffProfiles Staff[]
  bookings      Booking[]    @relation("CustomerBookings")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Tenancy & access control
// ============================================================

enum Role {
  OWNER
  STAFF
}

enum Plan {
  FREE
  PRO
}

model Tenant {
  id       String @id @default(cuid())
  name     String
  slug     String @unique
  timezone String @default("UTC")

  // Booking rules
  slotStepMinutes Int @default(15)
  bufferMinutes   Int @default(0)

  // Billing (Stripe)
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  subscriptionStatus   String?
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  staff       Staff[]
  services    Service[]
  bookings    Booking[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ============================================================
// Catalog & scheduling
// ============================================================

model Staff {
  id          String  @id @default(cuid())
  tenantId    String
  // Optional link to a login (STAFF membership). Null = managed-only staff.
  userId      String?
  displayName String
  bio         String?
  imageUrl    String?
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  services     StaffService[]
  workingHours WorkingHours[]
  timeOff      TimeOff[]
  bookings     Booking[]

  @@index([tenantId])
  @@index([userId])
}

model Service {
  id              String  @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int     @default(0)
  color           String  @default("#10b981")
  active          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff    StaffService[]
  bookings Booking[]

  @@index([tenantId])
}

// Which staff member can perform which service (many-to-many).
model StaffService {
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@index([serviceId])
}

// Recurring weekly availability for a staff member (in tenant-local time).
model WorkingHours {
  id           String @id @default(cuid())
  staffId      String
  weekday      Int // 0 = Sunday ... 6 = Saturday
  startMinutes Int // minutes from local midnight
  endMinutes   Int

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

// One-off unavailable ranges (vacation, sick day, etc.) in absolute time.
model TimeOff {
  id      String   @id @default(cuid())
  staffId String
  startAt DateTime
  endAt   DateTime
  reason  String?

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Booking {
  id         String        @id @default(cuid())
  tenantId   String
  serviceId  String
  staffId    String
  customerId String
  startAt    DateTime
  endAt      DateTime
  status     BookingStatus @default(CONFIRMED)
  notes      String?

  // Snapshot of customer/price at booking time (history integrity)
  customerName  String
  customerEmail String
  customerPhone String?
  priceCents    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service  Service @relation(fields: [serviceId], references: [id])
  staff    Staff   @relation(fields: [staffId], references: [id])
  customer User    @relation("CustomerBookings", fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([staffId, startAt])
  @@index([customerId])
}
